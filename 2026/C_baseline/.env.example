# 复制为 .env 并填入真实值。使用 OpenAI 兼容端点（DeepSeek / 通义千问 等）。
# 大模型（语义判断/Agent推理；走云 API，本地 RTX4070S 不需要跑大模型）
LLM_API_KEY=sk-xxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1     # 或 https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=deepseek-chat                       # 或 qwen-plus 等

# 向量嵌入（可用云端，也可本地 RTX4070S 跑 bge-m3 等）
EMBED_API_KEY=sk-xxxxxxxx
EMBED_BASE_URL=https://api.deepseek.com/v1    # 或本地 ollama/text-embeddings-inference
EMBED_MODEL=text-embedding-3-large            # 或 bge-m3 / text-embedding-v3
EMBED_DIM=1024
